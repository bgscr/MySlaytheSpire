[gd_resource type="Resource" script_class="CardDef" load_steps=6 format=3]

[ext_resource type="Script" path="res://scripts/data/card_def.gd" id="1_card"]
[ext_resource type="Script" path="res://scripts/data/effect_def.gd" id="2_effect"]
[ext_resource type="Script" path="res://scripts/data/card_presentation_cue_def.gd" id="3_cue"]

[sub_resource type="Resource" id="Resource_block"]
script = ExtResource("2_effect")
effect_type = "block"
amount = 3
target = "player"

[sub_resource type="Resource" id="Resource_status"]
script = ExtResource("2_effect")
effect_type = "apply_status"
amount = 2
status_id = "sword_focus"
target = "player"


[sub_resource type="Resource" id="Resource_player_particle_cue"]
script = ExtResource("3_cue")
event_type = "particle_burst"
target_mode = "player"
intensity = 1.0
cue_id = "sword.sword_resonance"

[resource]
script = ExtResource("1_card")
id = "sword.sword_resonance"
name_key = "card.sword.sword_resonance.name"
description_key = "card.sword.sword_resonance.desc"
cost = 1
card_type = "skill"
rarity = "uncommon"
effects = Array[ExtResource("2_effect")]([SubResource("Resource_block"), SubResource("Resource_status")])
presentation_cues = Array[ExtResource("3_cue")]([SubResource("Resource_player_particle_cue")])
character_id = "sword"
pool_tags = Array[String](["starter"])
reward_weight = 100
