[gd_resource type="Resource" script_class="CardDef" load_steps=7 format=3]

[ext_resource type="Script" path="res://scripts/data/card_def.gd" id="1_card"]
[ext_resource type="Script" path="res://scripts/data/effect_def.gd" id="2_effect"]
[ext_resource type="Script" path="res://scripts/data/card_presentation_cue_def.gd" id="3_cue"]

[sub_resource type="Resource" id="Resource_damage"]
script = ExtResource("2_effect")
effect_type = "damage"
amount = 8
target = "enemy"

[sub_resource type="Resource" id="Resource_poison"]
script = ExtResource("2_effect")
effect_type = "apply_status"
amount = 3
status_id = "poison"
target = "enemy"


[sub_resource type="Resource" id="Resource_target_particle_cue"]
script = ExtResource("3_cue")
event_type = "particle_burst"
target_mode = "played_target"
intensity = 1.0
cue_id = "alchemy.mercury_bloom"

[sub_resource type="Resource" id="Resource_camera_cue"]
script = ExtResource("3_cue")
event_type = "camera_impulse"
target_mode = "none"
intensity = 1.0
cue_id = "alchemy.mercury_bloom"

[resource]
script = ExtResource("1_card")
id = "alchemy.mercury_bloom"
name_key = "card.alchemy.mercury_bloom.name"
description_key = "card.alchemy.mercury_bloom.desc"
cost = 2
card_type = "attack"
rarity = "uncommon"
effects = Array[ExtResource("2_effect")]([SubResource("Resource_damage"), SubResource("Resource_poison")])
presentation_cues = Array[ExtResource("3_cue")]([SubResource("Resource_target_particle_cue"), SubResource("Resource_camera_cue")])
character_id = "alchemy"
pool_tags = Array[String](["wave_1"])
reward_weight = 100
