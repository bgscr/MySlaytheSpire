[gd_resource type="Resource" script_class="CardDef" load_steps=7 format=3]

[ext_resource type="Script" path="res://scripts/data/card_def.gd" id="1_card"]
[ext_resource type="Script" path="res://scripts/data/effect_def.gd" id="2_effect"]
[ext_resource type="Script" path="res://scripts/data/card_presentation_cue_def.gd" id="3_cue"]

[sub_resource type="Resource" id="Resource_block"]
script = ExtResource("2_effect")
effect_type = "block"
amount = 5
target = "player"

[sub_resource type="Resource" id="Resource_poison"]
script = ExtResource("2_effect")
effect_type = "apply_status"
amount = 1
status_id = "poison"
target = "enemy"


[sub_resource type="Resource" id="Resource_player_particle_cue"]
script = ExtResource("3_cue")
event_type = "particle_burst"
target_mode = "player"
intensity = 1.0
cue_id = "alchemy.smoke_screen"

[sub_resource type="Resource" id="Resource_target_particle_cue"]
script = ExtResource("3_cue")
event_type = "particle_burst"
target_mode = "played_target"
intensity = 1.0
cue_id = "alchemy.smoke_screen"

[resource]
script = ExtResource("1_card")
id = "alchemy.smoke_screen"
name_key = "card.alchemy.smoke_screen.name"
description_key = "card.alchemy.smoke_screen.desc"
cost = 1
card_type = "skill"
rarity = "common"
effects = Array[ExtResource("2_effect")]([SubResource("Resource_block"), SubResource("Resource_poison")])
presentation_cues = Array[ExtResource("3_cue")]([SubResource("Resource_player_particle_cue"), SubResource("Resource_target_particle_cue")])
character_id = "alchemy"
pool_tags = Array[String](["wave_1"])
reward_weight = 100
