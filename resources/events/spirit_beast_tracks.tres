[gd_resource type="Resource" script_class="EventDef" load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/data/event_def.gd" id="1_event"]
[ext_resource type="Script" path="res://scripts/data/event_option_def.gd" id="2_option"]

[sub_resource type="Resource" id="Resource_chase"]
script = ExtResource("2_option")
id = "chase"
label_key = "event.spirit_beast_tracks.option.chase"
description_key = "event.spirit_beast_tracks.option.chase.desc"
min_hp = 6
hp_delta = -5
gold_delta = 28

[sub_resource type="Resource" id="Resource_hide"]
script = ExtResource("2_option")
id = "hide"
label_key = "event.spirit_beast_tracks.option.hide"
description_key = "event.spirit_beast_tracks.option.hide.desc"
