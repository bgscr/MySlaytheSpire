[sub_resource type="Resource" id="Resource_leave"]
script = ExtResource("2_option")
id = "leave"
label_key = "event.spirit_beast_tracks.option.leave"
description_key = "event.spirit_beast_tracks.option.leave.desc"

[resource]
script = ExtResource("1_event")
id = "spirit_beast_tracks"
title_key = "event.spirit_beast_tracks.title"
body_key = "event.spirit_beast_tracks.body"
event_weight = 100
options = Array[ExtResource("2_option")]([SubResource("Resource_chase"), SubResource("Resource_hide"), SubResource("Resource_leave")])
